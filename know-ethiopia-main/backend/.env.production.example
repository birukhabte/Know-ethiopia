# Frontend URL (update after deploying to Vercel)
CLIENT_URL=https://your-frontend-name.vercel.app

# Notes:
# - Never commit this file with real values
# - Generate JWT_SECRET using: node ../generate-secrets.js
# - Update GOOGLE_CALLBACK_URL with your actual Render URL
# - Update CLIENT_URL with your actual Vercel URL
# - All these values should be set in Render dashboard, not in a file
